    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "latest",
    "multer": "^2.1.1",
    "react": "latest",
    "react-dom": "latest",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.22.0",
    "vite": "latest",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@testing-library/react": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "latest",
    "@types/react": "latest",
